# Copy this file to `.env` for local development on Windows.

# Required for live BTC pricing.
COINAPI_KEY=

# WalletConnect Project ID for RainbowKit (optional for basic local API testing).
WALLETCONNECT_PROJECT_ID=

# Polygon wallet private key used as the site's deposit/withdraw wallet.
SITE_WALLET_PK=

# Optional local JSON database path.
# If not set, the app stores data in ./data/plank-market.json
LOCAL_DB_FILE=
